<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>Email Prefix Generator</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <script>
    function CopyToClipboard() {
      if (navigator && navigator.clipboard) {
        navigator.clipboard.writeText("{{ result }}");
        console.log("Copying text using navigator.clipboard");
      } else {
        console.log("Copying text using document.execCommand");
        let valueField = document.querySelector("#value");
        valueField.focus();
        valueField.select();
        document.execCommand("copy");
      }
    }
  </script>
</head>

<body>
  {% if result != "" %}
  <input id="value" value="{{ result }}" />
  <button type="submit" style="display: block; margin-top: 5px" onclick="CopyToClipboard()">
    Copy to clipboard
  </button>
  {% endif %}
  <form method="get" style="display: block; margin-top: 20px">
    <label for="external_party">External Party*:</label>
    <input name="p" id="external_party" autocomplete="off" autofocus style="display: block; margin-top: 5px"
      value="{{ external_party }}" />
    <label for="domain" style="display: block; padding-top: 15px">Domain:</label>
    <input name="d" id="domain" style="display: block; margin-top: 5px" value="{{ domain }}" />
    <button type="submit" style="display: block; margin-top: 15px">
      Submit
    </button>
  </form>
</body>

</html>
